JIRA_BASE_URL=https://your-jira-host
HOST=0.0.0.0
PORT=3000
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your-jira-token
JIRA_JQL=assignee = currentUser() AND resolution = Unresolved ORDER BY updated DESC
JIRA_PERSONAL_JQL=statusCategory != Done ORDER BY updated DESC
JIRA_PERSONAL_ALLOWED_STATUSES=New,In Progress,To Do
JIRA_PERSONAL_ISSUE_TYPES=Bug,Sub-task,Story,Task
JIRA_MAX_RESULTS=50
JIRA_TEAM_JQL=assignee is not EMPTY AND statusCategory != Done ORDER BY priority DESC, updated DESC
JIRA_TEAM_MAX_RESULTS=50
JIRA_ASSIGNEE_FIELD=assignee
JIRA_ALLOW_SELF_SIGNED=false
DEFAULT_USER_EMAIL=user@company.com
BLOCKER_NOTIFY_WEBHOOK_URL=
BLOCKER_NOTIFY_PROVIDER=teams

# Optional: MongoDB (recommended for production notifications)
# MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<app>
MONGODB_DB=allinonw

# Optional: Nokia Directory (use /en/index.php for search; /oauth2/authorization/azure is OAuth entry only, 302 to Microsoft)
# DIRECTORY_URL=https://directory.int.net.nokia.com/en/index.php
# DIRECTORY_USER=your.nokia.email@nokia.com
# DIRECTORY_PASSWORD=your-password
# DIRECTORY_INSECURE=false

# Optional: Microsoft Graph (when directory redirects to Azure login). For 10k employees: set these and User.Read.All — auth context is fetched on demand, no local hierarchy file needed.
# Option A - App-only (recommended): get token with client_credentials, look up any user. App needs User.Read.All (admin consent).
# Option B - ROPC: use DIRECTORY_USER + DIRECTORY_PASSWORD below with your app's client_id/secret to get token for that user (app must allow ROPC in Azure).
AZURE_TENANT_ID=5d471751-9675-428d-917b-70f44f9630b0
AZURE_CLIENT_ID=02e107e7-a9d2-407b-8f8e-f8da5d759835
# From Azure → Certificates & secrets → New client secret → copy Value here (never commit .env):
AZURE_CLIENT_SECRET=
# DIRECTORY_USER=user@nokia.com
# DIRECTORY_PASSWORD=set-in-env-only-never-commit
